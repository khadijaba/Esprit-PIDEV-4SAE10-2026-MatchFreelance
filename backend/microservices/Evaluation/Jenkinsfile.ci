pipeline {
    agent any
    tools {
        jdk 'JDK17'
        maven 'Maven3'
    }
    options {
        skipDefaultCheckout(true)
        timeout(time: 90, unit: 'MINUTES')
    }
    environment {
        REPO_URL = 'https://github.com/khadijaba/Esprit-PIDEV-4SAE10-2026-MatchFreelance.git'
        BRANCH = 'douja'
        MODULE_DIR = 'backend/microservices/Evaluation'
        SONAR_PROJECT_KEY = 'evaluation'
        SONAR_HOST = 'http://sonarqube:9000'
        SONAR_CREDENTIALS_ID = 'sonar-token'
        IMAGE_NAME = 'khadijabenayed/evaluation'
        IMAGE_TAG = "1.0.${BUILD_NUMBER}"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${BRANCH}"]],
                    extensions: [
                        [$class: 'CloneOption', depth: 1, shallow: true, noTags: true, honorRefspec: true, timeout: 30],
                        [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
                            [$class: 'SparseCheckoutPath', path: 'backend/microservices/Evaluation']
                        ]]
                    ],
                    userRemoteConfigs: [[
                        credentialsId: 'github-credentials',
                        url: "${REPO_URL}",
                        refspec: "+refs/heads/${BRANCH}:refs/remotes/origin/${BRANCH}"
                    ]]
                ])
            }
        }
        stage('Build, Test, JaCoCo') {
            steps {
                dir("${MODULE_DIR}") {
                    sh '''
                        java -version
                        javac -version
                        mvn -B clean verify
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${MODULE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${MODULE_DIR}") {
                    withCredentials([string(credentialsId: "${SONAR_CREDENTIALS_ID}", variable: 'SONAR_TOKEN')]) {
                        retry(2) {
                            timeout(time: 5, unit: 'MINUTES') {
                                sh '''
                                    mvn -B sonar:sonar \
                                      -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                                      -Dsonar.host.url=${SONAR_HOST} \
                                      -Dsonar.token=${SONAR_TOKEN}
                                '''
                            }
                        }
                    }
                }
            }
        }
        stage('Build Jar') {
            steps {
                dir("${MODULE_DIR}") {
                    sh '''
                        mvn -B clean package -DskipTests
                    '''
                }
            }
        }
        stage('Docker Build & Push') {
            steps {
                dir("${MODULE_DIR}") {
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh '''
                            set -eux
                            getent hosts registry-1.docker.io || true
                            echo "${DOCKER_PASS}" | docker login -u "${DOCKER_USER}" --password-stdin
                            docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                            docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                            docker push ${IMAGE_NAME}:${IMAGE_TAG}
                            docker push ${IMAGE_NAME}:latest
                        '''
                    }
                }
            }
        }
        stage('Trigger CD') {
            steps {
                build job: 'evaluation-cd',
                      wait: false
            }
        }
    }
}
