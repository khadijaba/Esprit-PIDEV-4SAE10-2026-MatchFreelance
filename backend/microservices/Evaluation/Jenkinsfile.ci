pipeline {
    agent any
    tools {
        jdk 'JDK17'
        maven 'Maven3'
    }
    options {
        skipDefaultCheckout(true)
        timeout(time: 90, unit: 'MINUTES')
    }
    environment {
        REPO_URL = 'https://github.com/khadijaba/Esprit-PIDEV-4SAE10-2026-MatchFreelance.git'
        BRANCH = 'douja'
        MODULE_DIR = 'backend/microservices/Evaluation'
        SONAR_PROJECT_KEY = 'evaluation'
        SONAR_HOST = 'http://sonarqube:9000'
        SONAR_CREDENTIALS_ID = 'sonar-token'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: [[name: "*/${BRANCH}"]],
                    extensions: [
                        [$class: 'CloneOption', depth: 1, shallow: true, noTags: true, honorRefspec: true, timeout: 30],
                        [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
                            [$class: 'SparseCheckoutPath', path: 'backend/microservices/Evaluation']
                        ]]
                    ],
                    userRemoteConfigs: [[
                        credentialsId: 'github-credentials',
                        url: "${REPO_URL}",
                        refspec: "+refs/heads/${BRANCH}:refs/remotes/origin/${BRANCH}"
                    ]]
                ])
            }
        }
        stage('Build, Test, JaCoCo') {
            steps {
                dir("${MODULE_DIR}") {
                    sh '''
                        java -version
                        javac -version
                        mvn -B clean verify
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: "${MODULE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir("${MODULE_DIR}") {
                    withCredentials([string(credentialsId: "${SONAR_CREDENTIALS_ID}", variable: 'SONAR_TOKEN')]) {
                        retry(2) {
                            timeout(time: 5, unit: 'MINUTES') {
                                sh '''
                                    mvn -B sonar:sonar \
                                      -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                                      -Dsonar.host.url=${SONAR_HOST} \
                                      -Dsonar.token=${SONAR_TOKEN}
                                '''
                            }
                        }
                    }
                }
            }
        }
        stage('Trigger CD') {
            steps {
                build job: 'evaluation-cd',
                      wait: false
            }
        }
    }
}
