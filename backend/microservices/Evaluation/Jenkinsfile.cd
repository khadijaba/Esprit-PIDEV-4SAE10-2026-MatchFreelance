node {
    def repoUrl = 'https://github.com/khadijaba/Esprit-PIDEV-4SAE10-2026-MatchFreelance.git'
    def branch = 'douja'
    def moduleDir = 'backend/microservices/Evaluation'
    def imageName = 'khadijabenayed/evaluation'
    def imageTag = "1.0.${env.BUILD_NUMBER}"

    def jdkHome = tool(name: 'JDK17', type: 'hudson.model.JDK')
    if (!jdkHome?.trim()) {
        jdkHome = (env.JAVA_HOME ?: '').trim()
    }
    if (!jdkHome?.trim()) {
        error 'JDK17 (Global Tool Configuration) a un chemin vide : sous JDK17, clique « Ajouter un installateur », choisis par ex. Adoptium Temurin 17, enregistre. Sans installateur, Jenkins ne telecharge pas le JDK.'
    }

    withEnv([
        "JAVA_HOME=${jdkHome}",
        "PATH+JDK=${jdkHome}/bin"
    ]) {
        properties([
            disableConcurrentBuilds(),
            buildDiscarder(logRotator(numToKeepStr: '20'))
        ])

        timeout(time: 90, unit: 'MINUTES') {
            stage('Checkout') {
                retry(3) {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${branch}"]],
                        userRemoteConfigs: [[
                            credentialsId: 'github-credentials',
                            url: "${repoUrl}",
                            refspec: "+refs/heads/${branch}:refs/remotes/origin/${branch}"
                        ]],
                        extensions: [
                            [$class: 'CleanBeforeCheckout'],
                            [$class: 'PruneStaleBranch'],
                            [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [
                                [path: moduleDir],
                                [path: 'backend/microservices/k8s']
                            ]],
                            [$class: 'CloneOption', shallow: true, depth: 1, noTags: true, timeout: 30, honorRefspec: true, reference: '']
                        ]
                    ])
                }
            }

            stage('Deploy Kubernetes') {
                dir(moduleDir) {
                    withKubeConfig([credentialsId: 'kubeconfig-prod']) {
                        sh """
                            set -eux
                            kubectl apply --validate=false -f ../k8s/mysql.yaml
                            kubectl rollout status deployment/mysql --timeout=180s || true
                            kubectl apply --validate=false -f k8s/
                        """
                    }
                }
            }

            stage('Monitoring') {
                dir(moduleDir) {
                    withKubeConfig([credentialsId: 'kubeconfig-prod']) {
                        sh """
                            set -eux
                            kubectl rollout status deployment/evaluation --timeout=120s
                            kubectl get pods -l app=evaluation -o wide
                            kubectl get svc evaluation
                        """
                    }
                }
            }
        }
    }
}
