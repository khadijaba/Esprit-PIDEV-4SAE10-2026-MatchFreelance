node {
    def repoUrl = 'https://github.com/khadijaba/Esprit-PIDEV-4SAE10-2026-MatchFreelance.git'
    def branch = 'douja'
    def moduleDir = 'backend/microservices/Evaluation'
    def imageName = 'khadijabenayed/evaluation'
    def imageTag = "1.0.${env.BUILD_NUMBER}"

    def jdkHome = tool(name: 'JDK17', type: 'hudson.model.JDK')
    if (!jdkHome?.trim()) {
        jdkHome = (env.JAVA_HOME ?: '').trim()
    }
    if (!jdkHome?.trim()) {
        error 'JDK17 (Global Tool Configuration) a un chemin vide : sous JDK17, clique « Ajouter un installateur », choisis par ex. Adoptium Temurin 17, enregistre. Sans installateur, Jenkins ne telecharge pas le JDK.'
    }

    withEnv([
        "JAVA_HOME=${jdkHome}",
        "PATH+JDK=${jdkHome}/bin"
    ]) {
        properties([
            disableConcurrentBuilds(),
            buildDiscarder(logRotator(numToKeepStr: '20'))
        ])

        timeout(time: 90, unit: 'MINUTES') {
            stage('Checkout') {
                retry(3) {
                    checkout([
                        $class: 'GitSCM',
                        branches: [[name: "*/${branch}"]],
                        userRemoteConfigs: [[
                            credentialsId: 'github-credentials',
                            url: "${repoUrl}",
                            refspec: "+refs/heads/${branch}:refs/remotes/origin/${branch}"
                        ]],
                        extensions: [
                            [$class: 'CleanBeforeCheckout'],
                            [$class: 'PruneStaleBranch'],
                            [$class: 'SparseCheckoutPaths', sparseCheckoutPaths: [[path: moduleDir]]],
                            [$class: 'CloneOption', shallow: true, depth: 1, noTags: true, timeout: 30, honorRefspec: true, reference: '']
                        ]
                    ])
                }
            }

            stage('Build Jar') {
                dir(moduleDir) {
                    sh """
                        set -ex
                        test -x '${jdkHome}/bin/javac'
                        '${jdkHome}/bin/java' -version
                        mvn -B clean package -DskipTests \
                          -Dmaven.compiler.fork=true \
                          -Dmaven.compiler.executable='${jdkHome}/bin/javac'
                    """
                }
            }

            stage('Docker Build & Push') {
                dir(moduleDir) {
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh """
                            set -eux
                            getent hosts registry-1.docker.io || true
                            echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin
                            docker build -t '${imageName}:${imageTag}' .
                            docker tag '${imageName}:${imageTag}' '${imageName}:latest'

                            # Retry pushes because Docker Hub DNS/network can be temporarily unavailable.
                            n=0
                            until [ "\$n" -ge 3 ]
                            do
                                docker push '${imageName}:${imageTag}' && break
                                n=\$((n+1))
                                echo "docker push tag failed (attempt \$n/3), retry in 15s..."
                                sleep 15
                            done
                            [ "\$n" -lt 3 ] || { echo "Echec push image tag vers Docker Hub"; exit 1; }

                            n=0
                            until [ "\$n" -ge 3 ]
                            do
                                docker push '${imageName}:latest' && break
                                n=\$((n+1))
                                echo "docker push latest failed (attempt \$n/3), retry in 15s..."
                                sleep 15
                            done
                            [ "\$n" -lt 3 ] || { echo "Echec push image latest vers Docker Hub"; exit 1; }
                        """
                    }
                }
            }

            stage('Deploy Kubernetes') {
                dir(moduleDir) {
                    withKubeConfig([credentialsId: 'kubeconfig-prod']) {
                        sh """
                            set -eux
                            kubectl apply -f k8s/
                        """
                    }
                }
            }
        }
    }
}
