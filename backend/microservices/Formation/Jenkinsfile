pipeline {
    agent any

    environment {
        IMAGE_NAME = "formation-service"
        IMAGE_TAG = "1.0.${BUILD_NUMBER}"
        SONAR_HOST = "http://sonarqube:9000"
        MODULE_DIR = "backend/microservices/Formation"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'validation',
                    url: 'https://github.com/khadijaba/Esprit-PIDEV-4SAE10-2026-MatchFreelance.git'
            }
        }

        stage('Build Maven (Docker)') {
            steps {
                sh """
                docker run --rm \
                  -v ${WORKSPACE}:/app \
                  -w /app/${MODULE_DIR} \
                  maven:3-eclipse-temurin-17 \
                  mvn clean package -DskipTests
                """
            }
        }

        stage('Test') {
            steps {
                sh """
                docker run --rm \
                  -v ${WORKSPACE}:/app \
                  -w /app/${MODULE_DIR} \
                  maven:3-eclipse-temurin-17 \
                  mvn test
                """
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token-backend', variable: 'SONAR_TOKEN')]) {
                    sh """
                    docker run --rm \
                      -v ${WORKSPACE}:/app \
                      -w /app/${MODULE_DIR} \
                      maven:3-eclipse-temurin-17 \
                      mvn sonar:sonar \
                      -Dsonar.host.url=${SONAR_HOST} \
                      -Dsonar.token=${SONAR_TOKEN}
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ${MODULE_DIR}"
            }
        }

        stage('Docker Run') {
            steps {
                sh """
                docker rm -f formation-container || true
                docker run -d -p 9090:9090 --name formation-container ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
