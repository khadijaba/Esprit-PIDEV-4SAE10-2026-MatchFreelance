# Team AI - optional env vars
# TEAM_AI_HOST=0.0.0.0
# TEAM_AI_PORT=5000

# Backend (Gateway) URL for compatibility notifier (fetch skills + users)
# TEAM_AI_BACKEND_URL=http://localhost:8086

# Optional: use LLM for project analysis (OpenAI or Ollama)
# TEAM_AI_USE_LLM=true
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# For Ollama: OPENAI_BASE_URL=http://localhost:11434/v1
