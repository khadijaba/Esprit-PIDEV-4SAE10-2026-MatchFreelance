# Gateway / API (backend doit être démarré : Eureka, Gateway, microservices)
API_BASE_URL=http://localhost:8050

# Optionnel : token JWT si les routes API exigent une auth
# API_TOKEN=

# SMTP pour envoi des emails (rappels) — tous les freelancers reçoivent leur digest
# Gmail (benayedkhadija5@gmail.com) : mot de passe d'application requis (voir README)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=benayedkhadija5@gmail.com
SMTP_PASSWORD=ton_mot_de_passe_application_google
SMTP_FROM=benayedkhadija5@gmail.com

# Optionnel : webhook pour envoyer les rappels (POST JSON au lieu d'email)
# WEBHOOK_URL=https://your-server.com/webhook/rappels

# ETL : base analytique (SQLite par défaut)
ETL_DB_PATH=./data/analytics.db

# Lien plateforme dans les emails (optionnel)
# APP_BASE_URL=http://localhost:4200

# Toujours envoyer un email à ces adresses (même sans rappel ou si pas inscrit en FREELANCER)
# RAPPELS_ALWAYS_SEND_TO=khadijab.benayed@esprit.tn

# Envoyer un email à tous les freelancers même quand ils n'ont aucun rappel (true/false)
# SEND_EMAIL_WHEN_NO_RAPPELS=false

# Rappel « formation se termine dans X jours »
# RAPPEL_FORMATION_JOURS_AVANT_FIN=7
# Rappel « examen non passé après X jours » (inscription validée)
# RAPPEL_EXAMEN_JOURS_RETARD=14
# Webhook au format Slack / Teams (true pour envoyer un message lisible dans Slack)
# WEBHOOK_SLACK=false
