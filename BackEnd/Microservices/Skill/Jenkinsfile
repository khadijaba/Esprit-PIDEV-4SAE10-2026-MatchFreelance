pipeline {
    agent any

    tools {
        jdk 'JDK17'
        maven 'Maven3'
        git 'Default'
    }

    options {
        skipDefaultCheckout(true)
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    environment {
        MODULE_DIR = 'BackEnd/Microservices/Skill'
        SONAR_PROJECT_KEY = 'skill'
        SONAR_HOST = 'http://host.docker.internal:9000'
        SONAR_WS_TIMEOUT = '600'
        IMAGE_NAME = 'emna450/backend-skill'
        IMAGE_TAG = "1.0.${BUILD_NUMBER}"
        CD_JOB_NAME = 'pipeline-CD-skill-ms'
        K8S_NAMESPACE = 'skill'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    def branch = env.BRANCH_NAME ?: 'projectskills'
                    def exts = []
                    if (scm.extensions != null && !scm.extensions.isEmpty()) {
                        exts.addAll(scm.extensions)
                    }
                    exts.add([
                        $class       : 'CloneOption',
                        shallow      : true,
                        depth        : 1,
                        timeout      : 120,
                        honorRefspec : true,
                        noTags       : true,
                        reference    : ''
                    ])
                    def remotes = scm.userRemoteConfigs.collect { cfg ->
                        def m = [url: cfg.url]
                        if (cfg.credentialsId != null && cfg.credentialsId.toString().trim()) {
                            m.credentialsId = cfg.credentialsId
                        }
                        m.refspec = "+refs/heads/${branch}:refs/remotes/origin/${branch}"
                        m
                    }
                    checkout([
                        $class            : 'GitSCM',
                        branches          : [[name: "*/${branch}"]],
                        extensions        : exts,
                        userRemoteConfigs : remotes
                    ])
                }
            }
        }

        stage('Build & Package') {
            steps {
                dir("${env.MODULE_DIR}") {
                    sh '''
                        set -e
                        mvn -B clean package
                    '''
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${env.MODULE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }

        stage('Sonar Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                    dir("${env.MODULE_DIR}") {
                        sh """
                            mvn -B sonar:sonar \\
                              -Dsonar.projectKey=${env.SONAR_PROJECT_KEY} \\
                              -Dsonar.host.url=${env.SONAR_HOST} \\
                              -Dsonar.token=\${SONAR_TOKEN} \\
                              -Dsonar.ws.timeout=${env.SONAR_WS_TIMEOUT} \\
                              -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                        """
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${env.MODULE_DIR}") {
                    sh """
                        set -e
                        resolve_docker_cmd() {
                            if docker info > /dev/null 2>&1; then
                                echo "docker"
                                return 0
                            fi
                            if sudo -n docker info > /dev/null 2>&1; then
                                echo "sudo -n docker"
                                return 0
                            fi
                            return 1
                        }

                        DOCKER_CMD=\$(resolve_docker_cmd) || {
                            echo "Docker daemon inaccessible (/var/run/docker.sock permission denied)."
                            echo "Fix Jenkins agent rights: docker group for jenkins or passwordless sudo docker."
                            exit 1
                        }
                        echo "Using Docker command: \${DOCKER_CMD}"

                        \${DOCKER_CMD} image prune -f || true

                        # BuildKit peut provoquer des erreurs sporadiques en CI : fallback legacy builder.
                        export DOCKER_BUILDKIT=0
                        build_with_retry() {
                            n=0
                            until \${DOCKER_CMD} build --pull --no-cache -t ${env.IMAGE_NAME}:${env.IMAGE_TAG} .; do
                                n=\$((n + 1))
                                if [ "\$n" -ge 3 ]; then
                                    echo "docker build failed after \$n attempts"
                                    exit 1
                                fi
                                echo "docker build failed (attempt \$n), waiting 20s..."
                                sleep 20
                            done
                        }

                        build_with_retry
                        \${DOCKER_CMD} tag ${env.IMAGE_NAME}:${env.IMAGE_TAG} ${env.IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'docker-hub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh """
                        set -e
                        resolve_docker_cmd() {
                            if docker info > /dev/null 2>&1; then
                                echo "docker"
                                return 0
                            fi
                            if sudo -n docker info > /dev/null 2>&1; then
                                echo "sudo -n docker"
                                return 0
                            fi
                            return 1
                        }

                        DOCKER_CMD=\$(resolve_docker_cmd) || {
                            echo "Docker daemon inaccessible (/var/run/docker.sock permission denied)."
                            echo "Fix Jenkins agent rights: docker group for jenkins or passwordless sudo docker."
                            exit 1
                        }
                        echo "Using Docker command: \${DOCKER_CMD}"

                        \${DOCKER_CMD} image inspect ${env.IMAGE_NAME}:${env.IMAGE_TAG} > /dev/null
                        echo "\${DOCKER_PASS}" | \${DOCKER_CMD} login -u "\${DOCKER_USER}" --password-stdin

                        push_with_retry() {
                            img="\$1"
                            n=0
                            until \${DOCKER_CMD} push "\$img"; do
                                n=\$((n + 1))
                                if [ "\$n" -ge 4 ]; then
                                    echo "docker push failed for \$img after \$n attempts"
                                    exit 1
                                fi
                                echo "docker push \$img failed (attempt \$n), waiting 25s..."
                                sleep 25
                            done
                        }

                        push_with_retry ${env.IMAGE_NAME}:${env.IMAGE_TAG}

                        CURRENT_BRANCH="\${BRANCH_NAME:-\$(git rev-parse --abbrev-ref HEAD)}"
                        if [ "\${CURRENT_BRANCH}" = "main" ]; then
                            \${DOCKER_CMD} image inspect ${env.IMAGE_NAME}:latest > /dev/null
                            push_with_retry ${env.IMAGE_NAME}:latest
                        else
                            echo "Skip latest push on branch \${CURRENT_BRANCH}"
                        fi

                        \${DOCKER_CMD} logout
                    """
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build job: "${env.CD_JOB_NAME}",
                      wait: false,
                      parameters: [
                          string(name: 'IMAGE_TAG', value: "${env.IMAGE_TAG}"),
                          string(name: 'K8S_NAMESPACE', value: "${env.K8S_NAMESPACE}")
                      ]
            }
        }
    }
}
