pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Tag image a deployer (ex: 1.0.30)')
        string(name: 'K8S_NAMESPACE', defaultValue: 'matchfreelance', description: 'Namespace Kubernetes')
    }

    environment {
        IMAGE_NAME = 'emna450/project'
        MANIFESTS_DIR = 'BackEnd/Microservices/Project/k8s/project'
    }

    stages {
        stage('Deploy') {
            steps {
                withCredentials([file(credentialsId: 'kubeconfig-project', variable: 'KUBECONFIG_FILE')]) {
                    sh '''
                        set -e
                        EFFECTIVE_TAG="${IMAGE_TAG:-latest}"
                        EFFECTIVE_NS="${K8S_NAMESPACE:-matchfreelance}"
                        DEPLOY_IMAGE="${IMAGE_NAME}:${EFFECTIVE_TAG}"

                        export KUBECONFIG="${KUBECONFIG_FILE}"

                        if [ -d "${MANIFESTS_DIR}" ] && [ -f "${MANIFESTS_DIR}/deployment.yaml" ]; then
                          kubectl apply -f "${MANIFESTS_DIR}/namespace.yaml"
                          kubectl apply -f "${MANIFESTS_DIR}/mysql.yaml"
                          kubectl -n "${EFFECTIVE_NS}" rollout status deployment/mysql-project --timeout=900s
                          kubectl apply -f "${MANIFESTS_DIR}/deployment.yaml" -f "${MANIFESTS_DIR}/service.yaml"
                          kubectl -n "${EFFECTIVE_NS}" set image deployment/project-ms project-ms="${DEPLOY_IMAGE}"
                        else
                          kubectl -n "${EFFECTIVE_NS}" set image deployment/project-ms project-ms="${DEPLOY_IMAGE}"
                        fi

                        kubectl -n "${EFFECTIVE_NS}" rollout status deployment/project-ms --timeout=300s
                        kubectl -n "${EFFECTIVE_NS}" get pods,svc -l app=project-ms
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "CD OK: ${IMAGE_NAME}:${params.IMAGE_TAG} deploye dans ${params.K8S_NAMESPACE}."
        }
    }
}
