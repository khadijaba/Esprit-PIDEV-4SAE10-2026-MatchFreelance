/**
 * Pipeline CI — microservice Project
 *
 * Dépôt : https://github.com/khadijaba/Esprit-PIDEV-4SAE10-2026-MatchFreelance
 * Branche : projectskills
 * Chemin module : BackEnd/Microservices/Project
 *
 * Jenkins : sonar-token-backend, dockerhub-creds (si SKIP_DOCKER décoché)
 *
 * Clone : shallow + timeout pour éviter timeout / invalid index-pack sur gros dépôt.
 * Dans le job Git : branche = projectskills (spec Jenkins du type refs/heads/projectskills).
 *
 * Build / Sonar :
 *   - MAVEN_IN_DOCKER = true : mvn dans maven:3-eclipse-temurin-17 (docker run). Nécessite docker sur l’agent.
 *   - MAVEN_IN_DOCKER = false : mvn sur l’agent (installer JDK 17 + Maven, ou image Jenkins avec les outils).
 * Pas besoin du plugin Docker Pipeline pour docker run.
 */
pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
        timeout(time: 90, unit: 'MINUTES')
    }

    parameters {
        booleanParam(
            name: 'SKIP_DOCKER',
            defaultValue: true,
            description: 'Coché = pas de build/push image Docker (étapes Docker Build/Push)'
        )
        booleanParam(
            name: 'MAVEN_IN_DOCKER',
            defaultValue: false,
            description: 'Décoché (défaut) : mvn sur l’agent — à utiliser si « docker: not found ». Coché : mvn dans l’image maven (docker requis sur l’agent).'
        )
        string(
            name: 'SONAR_HOST_URL',
            defaultValue: 'http://host.docker.internal:9000',
            trim: true,
            description: 'URL SonarQube pour sonar:sonar. Sur Linux, souvent http://172.17.0.1:9000 ou le nom du service Compose.'
        )
    }

    environment {
        IMAGE_NAME = 'emna450/backend-project'
        IMAGE_TAG = "1.0.${BUILD_NUMBER}"
        SONAR_HOST = "${params.SONAR_HOST_URL}"
        /* Après checkout sur la branche projectskills */
        MODULE_DIR = 'BackEnd/Microservices/Project'
        SONAR_PROJECT_KEY = 'backend'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    /*
                     * Ne pas fetch refs/heads/* (toutes les branches) : trop lent sur gros dépôt.
                     * Une seule branche + shallow : GitHub ne renvoie qu’un petit pack.
                     * Multibranch : env.BRANCH_NAME est défini ; sinon défaut projectskills.
                     */
                    def branch = env.BRANCH_NAME ?: 'projectskills'
                    def exts = []
                    if (scm.extensions != null && !scm.extensions.isEmpty()) {
                        exts.addAll(scm.extensions)
                    }
                    exts.add([
                        $class       : 'CloneOption',
                        shallow      : true,
                        depth        : 1,
                        timeout      : 120,
                        honorRefspec : true,
                        noTags       : true,
                        reference    : ''
                    ])
                    def remotes = scm.userRemoteConfigs.collect { cfg ->
                        def m = [url: cfg.url]
                        if (cfg.credentialsId != null && cfg.credentialsId.toString().trim()) {
                            m.credentialsId = cfg.credentialsId
                        }
                        m.refspec = "+refs/heads/${branch}:refs/remotes/origin/${branch}"
                        m
                    }
                    checkout([
                        $class            : 'GitSCM',
                        branches          : [[name: "*/${branch}"]],
                        extensions        : exts,
                        userRemoteConfigs : remotes
                    ])
                }
            }
        }

        stage('Build & Test') {
            steps {
                script {
                    if (params.MAVEN_IN_DOCKER) {
                        sh """
                            docker run --rm \\
                              -v "${WORKSPACE}:/ws" \\
                              -w "/ws/${MODULE_DIR}" \\
                              maven:3-eclipse-temurin-17 \\
                              mvn -B clean verify
                        """
                    } else {
                        dir("${MODULE_DIR}") {
                            sh 'mvn -B clean verify'
                        }
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${MODULE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token-backend', variable: 'SONAR_TOKEN')]) {
                    script {
                        if (params.MAVEN_IN_DOCKER) {
                            sh """
                                docker run --rm \\
                                  -v "${WORKSPACE}:/ws" \\
                                  -w "/ws/${MODULE_DIR}" \\
                                  maven:3-eclipse-temurin-17 \\
                                  mvn -B sonar:sonar \\
                                    -Dsonar.projectKey=${SONAR_PROJECT_KEY} \\
                                    -Dsonar.host.url=${SONAR_HOST} \\
                                    -Dsonar.token=\${SONAR_TOKEN}
                            """
                        } else {
                            dir("${MODULE_DIR}") {
                                sh """
                                    mvn -B sonar:sonar \\
                                      -Dsonar.projectKey=${SONAR_PROJECT_KEY} \\
                                      -Dsonar.host.url=${SONAR_HOST} \\
                                      -Dsonar.token=\${SONAR_TOKEN}
                                """
                            }
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            when {
                expression { return !params.SKIP_DOCKER }
            }
            steps {
                dir("${MODULE_DIR}") {
                    sh """
                        docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Docker Push') {
            when {
                expression { return !params.SKIP_DOCKER }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh """
                        echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${IMAGE_NAME}:latest
                    """
                }
            }
        }
    }

    post {
        always {
            script {
                try {
                    cleanWs()
                } catch (ignored) {
                    /* Pas de workspace si le checkout a échoué avant l’alloc agent */
                }
            }
        }
    }
}
