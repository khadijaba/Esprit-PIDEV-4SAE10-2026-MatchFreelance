pipeline {
    agent any

    environment {
        APP_NAME = "project-service"
        IMAGE_TAG = "${env.BUILD_NUMBER}"
        REGISTRY = credentials('docker-registry-url')
        REGISTRY_CREDENTIALS = 'docker-registry-creds'
    }

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Java 17') {
            steps {
                sh 'java -version'
                sh 'mvn -version'
            }
        }

        stage('Clean package') {
            steps {
                sh 'mvn -B -ntp clean package -DskipTests'
            }
        }

        stage('Tests + JaCoCo') {
            steps {
                sh 'mvn -B -ntp verify'
            }
            post {
                always {
                    junit testResults: 'target/surefire-reports/*.xml', allowEmptyResults: true
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarqube-server') {
                    sh '''
                      mvn -B -ntp sonar:sonar \
                        -Dsonar.projectKey=project \
                        -Dsonar.coverage.jacoco.xmlReportPaths=target/site/jacoco/jacoco.xml
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t ${REGISTRY}/${APP_NAME}:${IMAGE_TAG} .'
            }
        }

        stage('Push Docker Image') {
            steps {
                withDockerRegistry(credentialsId: "${REGISTRY_CREDENTIALS}", url: "https://${REGISTRY}") {
                    sh 'docker push ${REGISTRY}/${APP_NAME}:${IMAGE_TAG}'
                    sh 'docker tag ${REGISTRY}/${APP_NAME}:${IMAGE_TAG} ${REGISTRY}/${APP_NAME}:latest'
                    sh 'docker push ${REGISTRY}/${APP_NAME}:latest'
                }
            }
        }

        stage('Trigger CD Pipeline') {
            when {
                branch 'projectskills'
            }
            steps {
                build job: 'Project-CD',
                      wait: false,
                      parameters: [
                          string(name: 'IMAGE_TAG', value: "${IMAGE_TAG}")
                      ]
            }
        }
    }
}
