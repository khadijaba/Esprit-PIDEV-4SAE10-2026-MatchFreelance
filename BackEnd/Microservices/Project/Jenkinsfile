/**
 * CI minimal — microservice Project (Maven + Sonar).
 * Job : « Pipeline script from SCM » sur le dépôt, branche projectskills (ou multibranche).
 * Outils Jenkins (noms exacts) : JDK17, Maven3, Git Default.
 * Credential : sonar-token-backend
 * Modifier SONAR_HOST ci-dessous si besoin (Linux conteneur : souvent http://172.17.0.1:9000).
 */
pipeline {
    agent any

    tools {
        jdk 'JDK17'
        maven 'Maven3'
        git 'Default'
    }

    options {
        timeout(time: 90, unit: 'MINUTES')
    }

    environment {
        MODULE_DIR = 'BackEnd/Microservices/Project'
        SONAR_PROJECT_KEY = 'backend'
        SONAR_HOST = 'http://host.docker.internal:9000'
    }

    stages {
        stage('Build & Sonar') {
            steps {
                withCredentials([string(credentialsId: 'sonar-token-backend', variable: 'SONAR_TOKEN')]) {
                    dir("${env.MODULE_DIR}") {
                        sh """
                            mvn -B clean verify sonar:sonar \\
                              -Dsonar.projectKey=${env.SONAR_PROJECT_KEY} \\
                              -Dsonar.host.url=${env.SONAR_HOST} \\
                              -Dsonar.token=\${SONAR_TOKEN}
                        """
                    }
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${env.MODULE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }
    }
}
