pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
        timeout(time: 90, unit: 'MINUTES')
    }

    parameters {
        booleanParam(
            name: 'SKIP_DOCKER',
            defaultValue: true,
            description: 'Coché = pas de build/push Docker (utile sans Docker sur l’agent)'
        )
    }

    environment {
        IMAGE_NAME = 'emna450/backend-project'
        IMAGE_TAG = "1.0.${BUILD_NUMBER}"
        SONAR_HOST = 'http://host.docker.internal:9000'
        /* Après checkout sur la branche projectskills */
        MODULE_DIR = 'BackEnd/Microservices/Project'
        SONAR_PROJECT_KEY = 'backend'
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    def exts = []
                    if (scm.extensions != null && !scm.extensions.isEmpty()) {
                        exts.addAll(scm.extensions)
                    }
                    exts.add([
                        $class           : 'CloneOption',
                        shallow          : true,
                        depth            : 1,
                        timeout          : 45,
                        honorRefspec     : true,
                        noTags           : true,
                        reference        : ''
                    ])
                    checkout([
                        $class             : 'GitSCM',
                        branches           : scm.branches,
                        extensions         : exts,
                        userRemoteConfigs  : scm.userRemoteConfigs
                    ])
                }
            }
        }

        stage('Build & Test') {
            steps {
                dir("${MODULE_DIR}") {
                    sh 'mvn -B clean verify'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: "${MODULE_DIR}/target/surefire-reports/*.xml"
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("${MODULE_DIR}") {
                    withCredentials([string(credentialsId: 'sonar-token-backend', variable: 'SONAR_TOKEN')]) {
                        sh """
                            mvn -B sonar:sonar \\
                              -Dsonar.projectKey=${SONAR_PROJECT_KEY} \\
                              -Dsonar.host.url=${SONAR_HOST} \\
                              -Dsonar.token=\${SONAR_TOKEN}
                        """
                    }
                }
            }
        }

        stage('Docker Build') {
            when {
                expression { return !params.SKIP_DOCKER }
            }
            steps {
                dir("${MODULE_DIR}") {
                    sh """
                        docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Docker Push') {
            when {
                expression { return !params.SKIP_DOCKER }
            }
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh """
                        echo "\${DOCKER_PASS}" | docker login -u "\${DOCKER_USER}" --password-stdin
                        docker push ${IMAGE_NAME}:${IMAGE_TAG}
                        docker push ${IMAGE_NAME}:latest
                    """
                }
            }
        }
    }

    post {
        always {
            script {
                try {
                    cleanWs()
                } catch (ignored) {
                    /* Pas de workspace si le checkout a échoué avant l’alloc agent */
                }
            }
        }
    }
}
