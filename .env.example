# Database Configuration
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=UserDB
MYSQL_USER=userapp
MYSQL_PASSWORD=your_database_password_here

# SendGrid Configuration
SENDGRID_API_KEY=your_sendgrid_api_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_minimum_256_bits

# Email Configuration
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_email_password_here

# OAuth2 Configuration
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=your_google_client_id
SPRING_SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=your_google_client_secret